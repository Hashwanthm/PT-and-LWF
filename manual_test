const fs = require("fs");
const path = require("path");

// Paste only the current token here.
// Do not upload or commit this file to GitHub.
const TOKEN = "PASTE_YOUR_TOKEN_HERE";

const CONFIG = {
  baseUrl: "https://adpvistahcm.ad.esi.adp.com",
  companyCode: "24X7tech",
  entityCode: "001",
  period: "2026APR",
  process: "All",
  fileType: "xlsx",
};

const reports = [
  {
    name: "PT",
    endpoint: "GetPTaxReport",
  },
  {
    name: "LWF",
    endpoint: "GetLwfReport",
  },
];

const downloadFolder = path.join(__dirname, "downloads");

function getAuthorizationHeader() {
  if (TOKEN.startsWith("Bearer ")) {
    return TOKEN;
  }

  return `Bearer ${TOKEN}`;
}

function getFilename(contentDisposition, fallbackName) {
  if (!contentDisposition) {
    return fallbackName;
  }

  const utf8Match = contentDisposition.match(
    /filename\*=UTF-8''([^;]+)/i,
  );

  if (utf8Match) {
    try {
      return decodeURIComponent(
        utf8Match[1].replace(/["']/g, "").trim(),
      );
    } catch {
      return fallbackName;
    }
  }

  const normalMatch = contentDisposition.match(
    /filename="?([^";]+)"?/i,
  );

  return normalMatch ? normalMatch[1].trim() : fallbackName;
}

function buildUrl(endpoint) {
  return (
    `${CONFIG.baseUrl}/ESSAPI/v1/VistaReports/Statutory/` +
    `${endpoint}/` +
    `${encodeURIComponent(CONFIG.companyCode)}/` +
    `${encodeURIComponent(CONFIG.entityCode)}/` +
    `${encodeURIComponent(CONFIG.period)}/` +
    `${encodeURIComponent(CONFIG.process)}` +
    `?fileType=${encodeURIComponent(CONFIG.fileType)}`
  );
}

async function downloadReport(report) {
  const url = buildUrl(report.endpoint);

  console.log(`\nTesting ${report.name} report...`);
  console.log(`URL: ${url}`);

  const response = await fetch(url, {
    method: "GET",

    headers: {
      Authorization: getAuthorizationHeader(),
      Accept: "application/json, text/plain, */*",
      "Content-Type": "application/json",
      "Cache-Control": "no-cache",
    },
  });

  console.log(`Status: ${response.status} ${response.statusText}`);

  const responseBuffer = Buffer.from(
    await response.arrayBuffer(),
  );

  if (!response.ok) {
    const errorText = responseBuffer.toString("utf8");

    console.error(`${report.name} failed.`);
    console.error("Server response:", errorText);

    return;
  }

  const contentDisposition = response.headers.get(
    "content-disposition",
  );

  const defaultFilename =
    `${report.name}_${CONFIG.companyCode}_` +
    `${CONFIG.entityCode}_${CONFIG.period}.zip`;

  const filename = getFilename(
    contentDisposition,
    defaultFilename,
  );

  const outputPath = path.join(downloadFolder, filename);

  fs.writeFileSync(outputPath, responseBuffer);

  console.log(`${report.name} downloaded successfully.`);
  console.log(`Saved at: ${outputPath}`);
}

async function main() {
  if (
    !TOKEN ||
    TOKEN === "PASTE_YOUR_TOKEN_HERE"
  ) {
    throw new Error("Paste your Vista token in the TOKEN variable.");
  }

  fs.mkdirSync(downloadFolder, {
    recursive: true,
  });

  for (const report of reports) {
    try {
      await downloadReport(report);
    } catch (error) {
      console.error(`${report.name} error:`, error.message);
    }
  }
}

main().catch((error) => {
  console.error("Test failed:", error.message);
  process.exitCode = 1;
});
